{
  "name": "n8n-nodes-fluidx",
  "version": "0.2.1",
  "description": "n8n community node for the fluidX revXR THE EYE API (sessions, inbound calls, SMS, email, media).",
  "keywords": [
    "n8n-community-node-package",
    "fluidx",
    "revxr",
    "theeye"
  ],
  "license": "MIT",
  "homepage": "https://github.com/titelplusplus/n8n-nodes-fluidx#readme",
  "author": {
    "name": "Titel++ / Revelate XR",
    "email": "titel@titelplusplus.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/titelplusplus/n8n-nodes-fluidx.git"
  },
  "bugs": {
    "url": "https://github.com/titelplusplus/n8n-nodes-fluidx/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": ">=20.15"
  },
  "main": "index.js",
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "format": "prettier nodes credentials --write",
    "lint": "eslint --ext .ts,.json nodes credentials package.json",
    "lintfix": "eslint --ext .ts,.json nodes credentials package.json --fix",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/FluidXApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/FluidX/FluidX.node.js"
    ]
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@typescript-eslint/parser": "^7.15.0",
    "eslint": "^8.57.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.3",
    "gulp": "^4.0.2",
    "n8n-workflow": "^1.82.0",
    "prettier": "^3.3.2",
    "typescript": "^5.5.3"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
